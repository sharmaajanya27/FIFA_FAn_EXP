# FanWatch discovery + engagement API — environment configuration
# Copy to .env and adjust. All values are optional; sensible defaults apply so
# the API runs locally with zero setup.

# Port the HTTP server listens on.
PORT=3001

# Directory holding the Phase 0 published JSONL (per-city subfolders).
# Defaults to the sibling ingestion package's output (../ingestion/data).
# Used only when DATABASE_URL is unset (see below).
# DATA_DIR=../ingestion/data

# Default search radius (meters) when a request omits one.
DEFAULT_RADIUS_M=5000

# Anthropic API key for AI recommendations.
# Absent → the API falls back to the deterministic heuristic recommender.
# ANTHROPIC_API_KEY=sk-ant-...

# Claude model id for AI recommendations.
AI_MODEL=claude-opus-4-8

# Comma-separated emails allowed to read the analytics/admin dashboard
# (GET /analytics/summary and the frontend /admin page). Case-insensitive.
# Absent → no one can access admin; set your own account here.
# ADMIN_EMAILS=you@example.com,teammate@example.com

# Postgres/Supabase connection string. Set → the API reads discovery from the
# venues/matches/events tables (PgRepository) and engagement from the
# engagement table (PgStore). Unset → local JSONL files under DATA_DIR.
# Apply supabase/migrations/0001_init.sql first. TLS is required for non-local
# hosts (auto-enabled); localhost connects without TLS.
# DATABASE_URL=postgres://user:pass@host:5432/postgres

# Supabase project URL — enables JWKS-based request-level auth.
# When set, all API requests (except /health) must carry a valid
# X-Supabase-Auth JWT header signed by this project's Auth signing key.
# Unset → verification disabled (local dev).
# SUPABASE_URL=https://your-ref.supabase.co
