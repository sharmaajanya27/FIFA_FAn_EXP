# FanWatch discovery + engagement API — environment configuration
# Copy to .env and adjust. All values are optional; sensible defaults apply so
# the API runs locally with zero setup.

# Port the HTTP server listens on.
PORT=3001

# Directory holding the Phase 0 published JSONL (per-city subfolders).
# Defaults to the sibling ingestion package's output (../ingestion/data).
# In production this is replaced by a database connection (Repository swap).
# DATA_DIR=../ingestion/data

# Default search radius (meters) when a request omits one.
DEFAULT_RADIUS_M=5000

# Anthropic API key for AI recommendations.
# Absent → the API falls back to the deterministic heuristic recommender.
# ANTHROPIC_API_KEY=sk-ant-...

# Claude model id for AI recommendations.
AI_MODEL=claude-opus-4-8

# --- Production-only (not read by the current code; reserved for the
# --- Postgres/auth migration documented in ARCHITECTURE.md §2) ---
# DATABASE_URL=postgres://user:pass@host:5432/fanwatch
