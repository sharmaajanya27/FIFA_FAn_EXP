# Base URL of the FanWatch discovery API (Phase 1 backend).
# Defaults to http://localhost:3001 if unset.
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Absolute public origin of the site — used for canonical URLs, Open Graph
# tags, and the sitemap. Swap to the production domain when live.
# Defaults to https://fanwatch.app if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI matchday pitch (natural-language recommendation). Kept in the codebase for
# a future launch but OFF by default until the Claude workflow is wired in.
# Set to "true" to preview the Smart/AI toggle locally.
# NEXT_PUBLIC_ENABLE_AI_PITCH=true

# Supabase anonymous auth — required for request-level authentication.
# Get these from your Supabase project dashboard.
# URL: Settings → General → Project URL
# Key: Settings → API Keys → Publishable key (sb_publishable_...)
#      or Legacy tab → anon key (eyJ...)
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
