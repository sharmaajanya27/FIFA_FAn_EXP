# FanMatch ingestion — environment configuration
# Copy to .env and adjust. All values are optional; sensible defaults apply.

# Overpass API endpoint (OpenStreetMap). Public instances are rate-limited;
# be a good citizen. Alternatives: https://overpass.kumi.systems/api/interpreter
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Contact string sent in the User-Agent (OSM etiquette / fair use).
INGEST_USER_AGENT=FanMatch-Ingestion/0.0.1 (contact: you@example.com)

# Milliseconds to wait between Overpass requests (politeness / rate limiting).
OVERPASS_THROTTLE_MS=1500

# Output directory for JSONL + Excel artifacts (relative to ingestion/).
DATA_DIR=data
