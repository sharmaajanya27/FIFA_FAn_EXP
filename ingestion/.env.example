# FanWatch ingestion — environment configuration
# Copy to .env and adjust. All values are optional; sensible defaults apply.

# Overpass API endpoint (OpenStreetMap). Public instances are rate-limited;
# be a good citizen. Alternatives: https://overpass.kumi.systems/api/interpreter
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Contact string sent in the User-Agent (OSM etiquette / fair use).
INGEST_USER_AGENT=FanWatch-Ingestion/0.0.1 (contact: you@example.com)

# Milliseconds to wait between Overpass requests (politeness / rate limiting).
OVERPASS_THROTTLE_MS=1500

# Output directory for JSONL + Excel artifacts (relative to ingestion/).
DATA_DIR=data

# Optional: live fixtures JSON URL (same shape as src/seeds/matches.*.json).
# Leave unset to use the bundled seed. This is where a keyed live fixtures
# source (e.g. football-data.org / OpenFootball mirror) plugs in.
# FIXTURES_URL=https://example.com/worldcup-2026.json

# Optional: Postgres/Supabase connection string. Set → ingestion dual-writes
# canonical venues/matches/events into the DB (SupabasePublisher) alongside the
# local JSONL + Excel artifacts, which remain the source of truth and rollback
# path. Apply supabase/migrations/0001_init.sql first. TLS is required for
# non-local hosts (auto-enabled); localhost connects without TLS.
# DATABASE_URL=postgres://user:pass@host:5432/postgres
